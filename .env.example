# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.tembeaafrica.com
NEXT_PUBLIC_SOCKET_URL=https://api.tembeaafrica.com

# ─── MAPS ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ─── PAYMENTS ────────────────────────────────────────────────────────────────
